[Unit]
Description=Vera Frontend (Vite)
After=network.target vera-backend.service

[Service]
Type=simple
User=root
WorkingDirectory=/home/vera-agent-main/frontend
ExecStart=/usr/bin/npx vite --host 0.0.0.0 --port 3000
Restart=always
RestartSec=3
Environment=NODE_ENV=production
StandardOutput=append:/var/log/vera-frontend.log
StandardError=append:/var/log/vera-frontend.log

[Install]
WantedBy=multi-user.target
