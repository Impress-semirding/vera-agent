[Unit]
Description=Vera Backend (FastAPI + uvicorn)
After=network.target docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/home/vera-agent-main/backend
EnvironmentFile=/home/vera-agent-main/backend/.env
ExecStart=/home/vera-agent-main/backend/.venv/bin/uvicorn api.main:app --host 0.0.0.0 --port 18080
Restart=always
RestartSec=3
StandardOutput=append:/var/log/vera-backend.log
StandardError=append:/var/log/vera-backend.log

[Install]
WantedBy=multi-user.target
