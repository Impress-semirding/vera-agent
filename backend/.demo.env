# =============================================================================
# Vera Backend Configuration
# Copy to .env and adjust as needed.
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
REASONIX_API_HOST=127.0.0.1
REASONIX_API_PORT=18080
REASONIX_API_RELOAD=
REASONIX_API_LOG_LEVEL=info
# Session token signing secret — CHANGE in production to a random 64-char string
VERA_SESSION_SECRET=

# ── Outbound MCP JWT (RS256) ─────────────────────────────────────────────────
# 为出站 http/sse MCP 调用签发 JWT；资源服务器（如 mysql_mcp）持配对公钥验签。
# 私钥 PEM 的换行用字面 \n 表示（单行），例如：
#   VERA_MCP_JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
# 本地生成：openssl genrsa -out mcp_jwt_private.pem 2048
# **绝不提交**：私钥只能进 .env（已被 .gitignore 忽略）或 KMS/Secrets Manager。
VERA_MCP_JWT_PRIVATE_KEY=
# 预期签发方标识（资源服务器侧 JWT_ISSUER 须与之相同）
VERA_MCP_JWT_ISSUER=vera-agent
# JWT 有效期（秒），需 ≥ 单次会话最长时长，否则会话中途 token 失效
VERA_MCP_JWT_TTL=3600

# ── LLM Provider ─────────────────────────────────────────────────────────────
# DEEPSEEK_API_KEY=sk-your-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Agent Runtime ────────────────────────────────────────────────────────────
# Use Docker for agent isolation (1=yes, 0=no/use local subprocess)
AGENT_USE_DOCKER=1
# Docker image name for the agent runner (must be pre-built)
AGENT_DOCKER_IMAGE=vera-agent-runner:latest
# Base directory for agent workspace files
# AGENT_WORKSPACE_BASE=./data/workspaces

# ── User Concurrency Limits ──────────────────────────────────────────────────
# Max concurrent turn-processing slots per user (across all their sessions).
# Sessions are multiplexed over one WS, so there's no session-count limit —
# this semaphore is the only concurrency cap (bounded also by the container pool).
AGENT_MAX_CONCURRENT_TURNS=2

# ── WeChat iLink ─────────────────────────────────────────────────────────────
# API key for the Anthropic-compatible proxy endpoint (deprecated, kept for compat)
# ANTHROPIC_API_PROXY_KEY=vera-proxy-key

# ── DingTalk OAuth (dingtalk-auth) ───────────────────────────────────────────
# 必填：钉钉开放平台 → 应用开发 → 你的应用 → 凭证与基础信息
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
# 必填：钉钉「登录与分享/安全设置」里配置的回调地址（必须和开放平台一致）
DINGTALK_REDIRECT_URI=http://localhost:3000/login/dingtalk/callback
# 下面三项有默认值，一般不用改
DINGTALK_AUTHORIZE_URL=https://login.dingtalk.com/oauth2/auth
DINGTALK_TOKEN_URL=https://api.dingtalk.com/v1.0/oauth2/userAccessToken
DINGTALK_USERINFO_URL=https://api.dingtalk.com/v1.0/contact/users/me
